generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ConversationType {
  DAILY_CHECKIN
  SOCIAL_COACHING
  GENERAL
  CRISIS
}

enum MessageRole {
  USER
  ASSISTANT
}

enum EmotionTag {
  HAPPY
  SAD
  ANXIOUS
  LONELY
  ANGRY
  NEUTRAL
}

enum SocialGoalStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum ConnectionEventType {
  ONBOARDING_COMPLETE
  DAILY_CHECKIN
  GOAL_COMPLETED
  REAL_WORLD_INTERACTION
  COACHING_COMPLETED
  STREAK_MILESTONE
  STREAK_7_BONUS
  CHECKIN_STREAK
  BADGE_UNLOCKED
  SCORE_ADJUSTMENT
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String?   @unique
  emailVerified       DateTime?
  image               String?
  createdAt           DateTime  @default(now())
  onboardingComplete  Boolean   @default(false)
  hasSeenTutorial     Boolean   @default(false)
  connectionScore     Int       @default(10)
  timezone            String?
  city                String?
  anxietyLevel        Int?
  voicePreferred      Boolean   @default(false)
  onboardingSituations Json?
  memorySnippet       String?

  // Profile fields shown on /account
  age                 Int?
  sex                 String?   // free text: "male", "female", "nonbinary", "prefer not to say", etc.
  interests           String[]  @default([])
  likes               String?
  dislikes            String?
  bio                 String?

  // Notification preferences — JSON for forward-compatibility
  // Shape: { enabled: boolean, morning: boolean, midday: boolean, evening: boolean, quietStart: number (0-23), quietEnd: number (0-23) }
  pushPrefs           Json?

  // Energy system (orb)
  energy              Int       @default(100)     // 0-100
  lastEnergyUpdate    DateTime  @default(now())   // last time energy was calculated
  lastPlanGeneratedAt DateTime?                   // for 7-day rolling cooldown

  // Subscription fields
  stripeCustomerId    String?
  subscriptionStatus  String    @default("free") // free, trialing, active, canceled, past_due
  subscriptionPlan    String    @default("free") // free, plus, care_plus
  trialEnd            DateTime?
  currentPeriodEnd    DateTime?

  accounts           Account[]
  sessions           Session[]
  conversations      Conversation[]
  socialGoals        SocialGoal[]
  events             ConnectionEvent[]
  streak             UserStreak?
  crisisLogs         CrisisLog[]
  pushSubscriptions  PushSubscription[]
  memories           UserMemory[]
  coins               Int       @default(0)       // virtual currency

  lifeOsProfile      LifeOsProfile?
  weeklyPlans        WeeklyPlan[]
  inventory          PetInventory[]
  equippedItems      PetEquipped[]

  @@index([subscriptionStatus])
  @@index([stripeCustomerId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   // client public key (base64url)
  auth      String   // auth secret (base64url)
  userAgent String?
  createdAt DateTime @default(now())
  lastUsed  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// Life OS — the user's annual operating system. One per user.
/// Stored as flexible JSON so sections can evolve without migrations.
model LifeOsProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      Json     // see LifeOsData type in lib/life-os/types
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// A generated week plan. Regenerated every Sunday (or on demand) from LifeOsProfile.
model WeeklyPlan {
  id         String   @id @default(cuid())
  userId     String
  weekStart  DateTime // Monday 00:00 in user's local tz (stored UTC)
  data       Json     // see WeeklyPlanData type
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId, weekStart])
}

/// Structured long-term memory extracted from user conversations.
/// Layer 1 on User.memorySnippet (rolling summary) is kept; this adds retrievable facts.
model UserMemory {
  id         String   @id @default(cuid())
  userId     String
  category   String   // "preference" | "person" | "goal" | "struggle" | "routine" | "fact"
  content    String   @db.Text
  confidence Float    @default(0.7) // 0..1 — how sure the model was
  source     String?  // conversationId the fact was pulled from
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category])
  @@index([userId, lastSeenAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  email     String
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expires])
}

model Conversation {
  id          String           @id @default(cuid())
  userId      String
  title       String
  type        ConversationType
  scenarioId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  lastReadAt  DateTime?
  crisisFlaggedAt      DateTime? // user message tripped crisis detection (server-side)
  crisisFollowUpDueAt  DateTime? // next UTC midnight - cue for tomorrow check-in follow-up

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId, type])
  @@index([userId, updatedAt])
  @@index([userId, crisisFollowUpDueAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  emotionTag     EmotionTag?
  voiceUsed      Boolean      @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model SocialGoal {
  id          String           @id @default(cuid())
  userId      String
  title       String
  description String           @db.Text
  targetDate  DateTime?
  status      SocialGoalStatus @default(ACTIVE)
  completedAt DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model ConnectionEvent {
  id            String               @id @default(cuid())
  userId        String
  type          ConnectionEventType
  note          String?              @db.Text
  pointsAwarded Int                  @default(0)
  badgeKey      String?
  createdAt     DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserStreak {
  id                String   @id @default(cuid())
  userId            String   @unique
  currentStreak     Int      @default(0)
  longestStreak     Int      @default(0)
  lastCheckInDate   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Pet Shop System (Tamagotchi economy) ──────────────────────────────────
enum ShopCategory {
  FOOD
  DRINK
  ACCESSORY
  BACKGROUND
  PERSONALITY
}

/// Catalog of items available in the pet shop
model ShopItem {
  id          String       @id @default(cuid())
  slug        String       @unique        // e.g. "hat-crown", "food-pizza"
  name        String
  description String
  category    ShopCategory
  price       Int                         // coin cost
  icon        String?                     // emoji or icon name
  rarity      String       @default("common") // common, rare, legendary
  effect      Json?                       // { energy?: number, moodBoost?: OrbMood, duration?: number }
  consumable  Boolean      @default(false)
  seasonal    Boolean      @default(false) // true = limited-time drop
  seasonTag   String?                     // e.g. "summer-2026", "halloween-2026"
  availableFrom DateTime?                 // start of availability window
  availableUntil DateTime?                // end of availability window (null = permanent)
  createdAt   DateTime     @default(now())

  inventory   PetInventory[]
  equipped    PetEquipped[]
}

/// Items a user owns (quantity tracked for consumables)
model PetInventory {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId])
}

/// Currently equipped accessories / active effects
model PetEquipped {
  id        String   @id @default(cuid())
  userId    String
  itemId    String
  slot      String   // "hat", "glasses", "background", "personality"
  equippedAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item ShopItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, slot]) // one item per slot
  @@index([userId])
}

model CrisisLog {
  id             String   @id @default(cuid())
  userId         String
  conversationId String?
  severity       String
  keywords       Json
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

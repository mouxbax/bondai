DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bondai?schema=public
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
EMAIL_FROM=noreply@yourdomain.com

# Stripe Configuration (https://stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...
NEXT_PUBLIC_STRIPE_PRICE_PLUS=price_...
NEXT_PUBLIC_STRIPE_PRICE_CARE_PLUS=price_...

# Optional: enable passwordless dev login in production-like environments
# AUTH_DEV_LOGIN=true

# Whisper transcription for voice chat (pick one)
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...

# Web Push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@yourdomain.com

# Cron auth — use a long random string
CRON_SECRET=
